{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Histogram of customer lifetime value (LTV)",
  "data": { "name": "table" },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "LTV",
      "type": "quantitative",
      "bin": { "maxbins": 40 },
      "axis": { "title": "Lifetime Value" }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "axis": { "title": "Customers" }
    },
    "tooltip": [
      { "field": "CustomerName", "type": "nominal", "title": "Customer" },
      {
        "field": "LTV",
        "type": "quantitative",
        "title": "LTV",
        "format": "$,.2f"
      }
    ]
  }
}
