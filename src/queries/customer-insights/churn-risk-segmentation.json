{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Bar chart of churn risk segments",
  "data": { "name": "table" },
  "mark": "bar",
  "encoding": {
    "x": {
      "field": "RiskSegment",
      "type": "ordinal",
      "axis": { "title": "Risk Segment" }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "axis": { "title": "Customers" }
    },
    "color": { "field": "RiskSegment", "type": "nominal" },
    "tooltip": [
      { "field": "CustomerName", "type": "nominal", "title": "Customer" },
      { "field": "ChurnScore", "type": "quantitative", "title": "Churn Score" }
    ]
  }
}
